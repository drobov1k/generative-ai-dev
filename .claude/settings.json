{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx tsc *)",
      "Bash(npx cdk *)",
      "Bash(pip install -r requirements.txt)",
      "Bash(pip list)",
      "Bash(python main.py)",
      "Bash(python -m pytest *)",
      "Bash(uvicorn *)",
      "Bash(curl -s *)",
      "Bash(curl -X POST *)",
      "Bash(find . -name *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/env-guard.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/update-docs.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/spec-sync-reminder.js"
          }
        ]
      }
    ]
  }
}
