# Copy to .env for local development
AWS_REGION=us-east-1
DOCUMENT_BUCKET=local-document-bucket

# Set to "true" to skip real Bedrock calls during local dev
MOCK_EMBEDDINGS=true
MOCK_GENERATION=true

# Vector store backend: memory | mock | qdrant | opensearch
VECTOR_STORE=memory

# Qdrant (when VECTOR_STORE=qdrant)
QDRANT_URL=http://localhost:6333

# Model IDs (defaults shown)
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
GENERATION_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
